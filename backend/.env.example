# Backend Environment Configuration Template
# Copy this file to .env and fill in the values

# Port the backend server runs on
PORT=5000

# MongoDB Connection String (Atlas or Local)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mbihuhs.mongodb.net/Smart_TaskManager
# OR for local: MONGO_URI=mongodb://127.0.0.1:27017/smart_task_manager

# Secret key used to sign JWT authentication tokens (use a long random string)
JWT_SECRET=super_secret_jwt_key_smart_task_manager_development_12345

# URL of your frontend application (used for CORS headers - omit/use '*' to allow all in development)
FRONTEND_URL=http://localhost:5173
